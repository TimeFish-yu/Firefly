---
import { getCollection } from "astro:content";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import fs from "node:fs";
import path from "node:path";

// 获取所有说说
const allSays = await getCollection("says");
const saysFiltered = allSays.filter((say) => !say.data.draft);

// 获取文件创建时间并转换为北京时间
const saysDir = path.join(process.cwd(), "src/content/says");
const says = saysFiltered.map((say) => {
  const filePath = path.join(saysDir, `${say.id}.md`);
  let fileDate = say.data.date || "";
  let timestamp = 0;
  
  try {
    const stats = fs.statSync(filePath);
    timestamp = stats.birthtimeMs; // 用毫秒时间戳排序
    // 使用文件创建时间（birthtime）
    if (!fileDate) {
      const utcDate = stats.birthtime;
      // 转换为北京时间 (UTC+8)
      const beijingTime = new Date(utcDate.getTime() + 8 * 60 * 60 * 1000);
      const pad = (n: number) => n.toString().padStart(2, "0");
      fileDate = `${beijingTime.getUTCFullYear()}-${pad(beijingTime.getUTCMonth() + 1)}-${pad(beijingTime.getUTCDate())} ${pad(beijingTime.getUTCHours())}:${pad(beijingTime.getUTCMinutes())}`;
    }
  } catch (e) {
    if (!fileDate) fileDate = say.id;
  }
  
  return {
    ...say,
    displayDate: fileDate,
    timestamp,
  };
}).sort((a, b) => b.timestamp - a.timestamp); // 按创建时间降序，最新的在前
---

<MainGridLayout title="说说" description="我的碎碎念">
  <div class="flex w-full">
    <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
      <h1 class="text-3xl font-bold mb-2">说说</h1>
      <p class="text-black/50 dark:text-white/50 mb-8">随口记录点什么~</p>

      <div class="relative pl-6 md:pl-8">
        <!-- 左侧时间线 -->
        <div class="absolute left-2 top-2 bottom-2 w-0.5 bg-black/10 dark:bg-white/10 rounded-full"></div>

        <div class="space-y-6">
          {says.map((say) => (
            <div class="relative">
              <!-- 时间线圆点 -->
              <div class="absolute -left-6 md:-left-8 top-1 w-4 h-4 rounded-full bg-[var(--primary)] border-4 border-white dark:border-[var(--card-bg)]"></div>
              
              <!-- 说说卡片 -->
              <article class="rounded-lg bg-black/3 dark:bg-white/3 p-4 md:p-6">
                <p class="text-xs text-black/30 dark:text-white/30 mb-3 font-mono">
                  {say.displayDate}
                </p>
                <div class="prose dark:prose-invert max-w-none" set:html={say.body} />
              </article>
            </div>
          ))}
        </div>
      </div>

      {says.length === 0 && (
        <div class="text-center text-black/30 dark:text-white/30 py-12">
          还没有说说，发第一条吧~
        </div>
      )}
    </div>
  </div>

  <!-- Twikoo 评论区 -->
  <div class="card-base w-full mt-4 px-6 md:px-9 py-6">
    <h2 class="text-xl font-bold mb-4">评论</h2>
    <div id="tcomment"></div>
    <script is:inline src="https://cdn.jsdelivr.net/npm/twikoo@1.6.39/dist/twikoo.all.min.js"></script>
    <script is:inline>
      twikoo.init({
        envId: 'https://twikoo.ezane.top/',
        el: '#tcomment',
        path: location.pathname,
      });
    </script>
  </div>
</MainGridLayout>
