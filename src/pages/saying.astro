---
import { getCollection } from "astro:content";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

// 获取所有说说并按文件名排序（文件名越大越新）
const allSays = await getCollection("says");
const says = allSays
  .filter((say) => !say.data.draft)
  .sort((a, b) => b.id.localeCompare(a.id));

// 格式化日期函数
function formatDate(dateStr: string | undefined, fileId: string): string {
  if (dateStr) return dateStr;
  // 没有指定日期时，显示文件ID
  return `#${fileId}`;
}
---

<MainGridLayout title="说说" description="我的碎碎念">
  <div class="flex w-full">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <h1 class="text-3xl font-bold mb-2">说说</h1>
      <p class="text-black/50 dark:text-white/50 mb-8">随口记录点什么~</p>

      <div class="space-y-4">
        {says.map((say) => (
          <article class="rounded-lg bg-black/3 dark:bg-white/3 p-4 md:p-6">
            <p class="text-xs text-black/30 dark:text-white/30 mb-3">
              {formatDate(say.data.date, say.id.replace(".md", ""))}
            </p>
            <div class="prose dark:prose-invert max-w-none" set:html={say.body} />
          </article>
        ))}
      </div>

      {says.length === 0 && (
        <div class="text-center text-black/30 dark:text-white/30 py-12">
          还没有说说，发第一条吧~
        </div>
      )}
    </div>
  </div>

  <!-- Twikoo 评论区 -->
  <div class="card-base w-full mt-4 px-9 py-6">
    <h2 class="text-xl font-bold mb-4">评论</h2>
    <div id="tcomment"></div>
    <script is:inline src="https://cdn.jsdelivr.net/npm/twikoo@1.6.39/dist/twikoo.all.min.js"></script>
    <script is:inline>
      twikoo.init({
        envId: 'https://twikoo.ezane.top/',  // 你的 Twikoo 环境地址
        el: '#tcomment',
        path: location.pathname,
      });
    </script>
  </div>
</MainGridLayout>
