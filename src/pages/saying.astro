---
import { getCollection } from "astro:content";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

// 获取所有说说并按 ID 排序（ID 是文件名，越新越大）
const allSays = await getCollection("says");
const says = allSays
  .filter((say) => !say.data.draft)
  .sort((a, b) => b.id.localeCompare(a.id));
---

<MainGridLayout title="说说" description="我的碎碎念">
  <div class="flex w-full">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <h1 class="text-3xl font-bold mb-2">说说</h1>
      <p class="text-black/50 dark:text-white/50 mb-8">随口记录点什么~</p>

      <div class="space-y-4">
        {says.map((say) => (
          <article class="rounded-lg bg-black/3 dark:bg-white/3 p-4 md:p-6">
            <div class="prose dark:prose-invert max-w-none" set:html={say.body} />
            {say.data.date && (
              <p class="text-xs text-black/30 dark:text-white/30 mt-3 mb-0">{say.data.date}</p>
            )}
          </article>
        ))}
      </div>

      {says.length === 0 && (
        <div class="text-center text-black/30 dark:text-white/30 py-12">
          还没有说说，发第一条吧~
        </div>
      )}
    </div>
  </div>

  <!-- Giscus 评论区 -->
  <div class="card-base w-full mt-4 px-9 py-6">
    <h2 class="text-xl font-bold mb-4">评论</h2>
    <script src="https://giscus.app/client.js"
      data-repo="TimeFish-yu/Firefly"
      data-repo-id="R_kgDOOIK0Yg"
      data-category="Announcements"
      data-category-id="DIC_kwDOOIK0Ys4Cq4n9"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="preferred_color_scheme"
      data-lang="zh-CN"
      crossorigin="anonymous"
      async>
    </script>
  </div>
</MainGridLayout>
